# Optional — for sending orders to Telegram.
# Leave everything blank to run fully offline (orders will be logged to the server console).

# --- Option A: Direct Telegram Bot (recommended for self-hosting) ---
# Create a bot via @BotFather, then put your bot token + target chat id here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Option B: Lovable connector gateway (only when deployed on Lovable) ---
# LOVABLE_API_KEY=
# TELEGRAM_API_KEY=
